{
  "manifest_version": 3,
  "name": "Clean TweetX",
  "version": "1.0.1",
  "description": "Cleans up X (Twitter) by hiding the sidebar, promoted tweets, Grok AI, and premium upsells.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
